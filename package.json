{
  "name": "aether",
  "version": "1.0.0",
  "description": "Beautiful, privacy-focused, multi-provider AI chat desktop application with Linear.app-inspired design",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:react\" \"npm run dev:electron\"",
    "dev:react": "vite",
    "dev:electron": "wait-on tcp:5173 && electron .",
    "build": "vite build",
    "build:mac": "npm run build && electron-builder --mac --config electron-builder.json",
    "build:win": "npm run build && electron-builder --win --config electron-builder.json",
    "build:linux": "npm run build && electron-builder --linux --config electron-builder.json",
    "build:all": "npm run build && electron-builder -mwl --config electron-builder.json",
    "pack": "electron-builder --dir --config electron-builder.json",
    "dist": "electron-builder --config electron-builder.json",
    "icons": "bash scripts/create-icons.sh",
    "release": "npm run build && electron-builder --publish always --config electron-builder.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\""
  },
  "keywords": [
    "ai",
    "chatbot",
    "electron",
    "desktop",
    "gemini",
    "claude",
    "openai",
    "vertex-ai",
    "linear-design",
    "privacy-first",
    "multi-provider",
    "react",
    "tailwindcss"
  ],
  "author": {
    "name": "Aether",
    "email": "hello@aether.app"
  },
  "license": "MIT",
  "dependencies": {
    "@google-cloud/vertexai": "^1.1.0",
    "chart.js": "^4.5.1",
    "clsx": "^2.1.0",
    "cmdk": "^1.1.1",
    "date-fns": "^3.3.1",
    "electron-store": "^8.1.0",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.0.3",
    "google-auth-library": "^9.6.3",
    "highlight.js": "^11.9.0",
    "idb": "^7.1.1",
    "lucide-react": "^0.576.0",
    "mermaid": "^11.12.3",
    "openai": "^4.28.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.2.0",
    "react-chartjs-2": "^5.3.1",
    "react-dom": "^18.2.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^9.0.1",
    "react-window": "^2.2.7",
    "reactflow": "^11.11.4",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@babel/core": "^7.23.9",
    "@babel/preset-env": "^7.23.9",
    "@babel/preset-react": "^7.23.3",
    "@testing-library/jest-dom": "^6.2.0",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "babel-jest": "^29.7.0",
    "concurrently": "^8.2.2",
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^9.0.10",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.35",
    "prettier": "^3.2.4",
    "tailwindcss": "^3.4.1",
    "vite": "^5.1.0",
    "wait-on": "^7.2.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/code-wiki/aether.git"
  },
  "bugs": {
    "url": "https://github.com/code-wiki/aether/issues"
  },
  "homepage": "https://github.com/code-wiki/aether#readme",
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,md}": [
      "prettier --write"
    ]
  }
}
