{
  "appId": "com.aether.app",
  "productName": "Aether",
  "copyright": "Copyright © 2024 Aether",
  "files": [
    "dist/**/*",
    "electron/**/*",
    "package.json"
  ],
  "directories": {
    "buildResources": "build",
    "output": "release"
  },
  "compression": "maximum",
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",

  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      {
        "target": "dmg",
        "arch": ["x64", "arm64"]
      },
      {
        "target": "zip",
        "arch": ["x64", "arm64"]
      }
    ],
    "icon": "build/icon.icns",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "entitlements": "build/entitlements.mac.plist",
    "entitlementsInherit": "build/entitlements.mac.plist",
    "darkModeSupport": true,
    "minimumSystemVersion": "10.13.0"
  },

  "dmg": {
    "title": "${productName} ${version}",
    "icon": "build/icon.icns",
    "contents": [
      {
        "x": 130,
        "y": 220
      },
      {
        "x": 410,
        "y": 220,
        "type": "link",
        "path": "/Applications"
      }
    ],
    "window": {
      "width": 540,
      "height": 400
    },
    "backgroundColor": "#ffffff",
    "internetEnabled": false,
    "sign": false
  },

  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64", "ia32"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icon.ico",
    "publisherName": "Aether",
    "verifyUpdateCodeSignature": false
  },

  "nsis": {
    "oneClick": false,
    "perMachine": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "Aether",
    "include": "build/installer.nsh",
    "license": "LICENSE"
  },

  "linux": {
    "target": [
      {
        "target": "AppImage",
        "arch": ["x64"]
      },
      {
        "target": "deb",
        "arch": ["x64"]
      },
      {
        "target": "rpm",
        "arch": ["x64"]
      }
    ],
    "icon": "build/icons",
    "category": "Utility",
    "description": "Next-generation AI chatbot desktop application",
    "desktop": {
      "Name": "Aether",
      "Comment": "AI Chatbot",
      "Terminal": false,
      "Type": "Application",
      "Categories": "Utility;Network;Chat;"
    }
  },

  "deb": {
    "depends": ["gconf2", "gconf-service", "libnotify4", "libappindicator1", "libxtst6", "libnss3"]
  },

  "appImage": {
    "license": "LICENSE"
  },

  "publish": {
    "provider": "github",
    "owner": "code-wiki",
    "repo": "aether",
    "releaseType": "release"
  }
}
